# ============================================================================
# 🔐 VARIÁVEIS DE AMBIENTE - Trading Bot PRO 4.0
# ============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env no Git!
# ============================================================================

# --- MetaTrader 5 ---
MT5_LOGIN=seu_login_aqui
MT5_PASSWORD=sua_senha_aqui
MT5_SERVER=seu_servidor_aqui

# --- Telegram ---
# Para obter:
# 1. Fale com @BotFather no Telegram
# 2. Crie um bot com /newbot
# 3. Copie o token fornecido
# 4. Inicie conversa com seu bot e envie /start
# 5. Acesse: https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
# 6. Copie o chat_id da resposta

TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ============================================================================
# IMPORTANTE:
# - Adicione .env ao .gitignore
# - Nunca compartilhe essas credenciais
# - Revogue tokens antigos se foram expostos
# ============================================================================
